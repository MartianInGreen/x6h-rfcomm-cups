    function showPages(pages, index) {
      pdfPages = pages || [];
      pdfIndex = Math.max(0, Math.min(pdfPages.length - 1, index || 0));
      if (pdfPages.length === 0) {
        $("paper").innerHTML = '<div class="empty">Nothing to preview</div>';
        $("pageIndicator").textContent = "";
        $("prevPage").disabled = true;
        $("nextPage").disabled = true;
        $("previewMeta").textContent = "384 px print width";
        return;
      }
      const page = pdfPages[pdfIndex];
      $("paper").innerHTML = `<div class="paper-text"><img alt="Page ${pdfIndex + 1}" src="${page.preview}"></div>`;
      $("previewMeta").textContent = `${page.width} x ${page.height} px / ${page.lengthMm} mm`;
      $("pageIndicator").textContent = pdfPages.length > 1
        ? `Page ${pdfIndex + 1} of ${pdfPages.length}`
        : "";
      $("prevPage").disabled = pdfIndex <= 0;
      $("nextPage").disabled = pdfIndex >= pdfPages.length - 1;
    }

    $("prevPage").addEventListener("click", () => showPages(pdfPages, pdfIndex - 1));
    $("nextPage").addEventListener("click", () => showPages(pdfPages, pdfIndex + 1));

    async function postJson(path, payload) {
      const response = await fetch(path, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const body = await response.json();
      if (!response.ok) throw new Error(body.error || "Request failed");
      return body;
    }

    setTab("image");
  </script>
</body>
</html>
"""


def image_from_data_url(value: str) -> Image.Image:
    if "," in value:
        value = value.split(",", 1)[1]
    data = base64.b64decode(value)
    return Image.open(io.BytesIO(data))


def json_response(handler: BaseHTTPRequestHandler, status: int, payload: dict[str, Any]) -> None:
    body = json.dumps(payload).encode()
    handler.send_response(status)
    handler.send_header("Content-Type", "application/json")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)


def png_data_url(image: Image.Image) -> str:
    buf = io.BytesIO()
    image.convert("L").save(buf, format="PNG")
    return "data:image/png;base64," + base64.b64encode(buf.getvalue()).decode()


def mm_to_px(mm: float, dpi: int) -> int:
    return max(1, round(mm / 25.4 * dpi))


def settings_from_payload(server: "DashboardServer", payload: dict[str, Any]) -> Any:
    opts = payload.get("settings") or {}
    kwargs = dict(
        addr=server.printer_addr,
        channel=server.channel,
        darkness=int(opts.get("darkness", 9500)),
        speed=int(opts.get("speed", 10)),
        quality=3,
        threshold=int(opts.get("threshold", 180)),
        feed_lines=int(opts.get("feedLines", 60)),
        scale=str(opts.get("fit", "fit-width")) if "fit" in opts else "fit-width",
        dither=str(opts.get("dither", "floyd-steinberg")),
        dither_strength=float(opts.get("ditherStrength", 1.0)),
        ordered_size=4 if int(opts.get("orderedSize", 8)) <= 4 else 8,
        serpentine=bool(opts.get("serpentine", True)),
        brightness=float(opts.get("brightness", 1.0)),
        contrast=float(opts.get("contrast", 1.0)),
        gamma=float(opts.get("gamma", 1.0)),
        invert=bool(opts.get("invert", False)),
        orientation=str(opts.get("orientation", "auto")),
        trim=bool(opts.get("trim", True)),
        dpi=int(opts.get("dpi", 203)),
    )
    return core.Settings(**{key: value for key, value in kwargs.items() if key in CORE_FIELDS})


def core_warning() -> str | None:
    missing = sorted(REQUIRED_RASTER_FIELDS - CORE_FIELDS)
    if missing:
        return "Older printer core loaded; rerun the installer so raster controls apply."
    return None


def raster_summary(settings: Any) -> str:
    dither = getattr(settings, "dither", "none")
    threshold = getattr(settings, "threshold", 180)
    strength = getattr(settings, "dither_strength", 1.0)
    if dither in {"none", "threshold"}:
        return f"no dither, threshold {threshold}"
    if dither == "grayscale":
        return "4-bit grayscale"
    return f"{dither}, threshold {threshold}, strength {strength}"


def crop_image(image: Image.Image, opts: dict[str, Any]) -> Image.Image:
    left_pct = max(0.0, min(45.0, float(opts.get("cropLeft", 0)))) / 100
    right_pct = max(0.0, min(45.0, float(opts.get("cropRight", 0)))) / 100
    top_pct = max(0.0, min(45.0, float(opts.get("cropTop", 0)))) / 100
    bottom_pct = max(0.0, min(45.0, float(opts.get("cropBottom", 0)))) / 100
    left = round(image.width * left_pct)
    right = image.width - round(image.width * right_pct)
    top = round(image.height * top_pct)
    bottom = image.height - round(image.height * bottom_pct)
    if right <= left or bottom <= top:
        return image
    return image.crop((left, top, right, bottom))


def initial_grayscale(image: Image.Image, settings: Any, opts: dict[str, Any]) -> Image.Image:
    image = ImageOps.exif_transpose(image).convert("L")
    image = crop_image(image, opts)
    if settings.trim:
        image = core.trim_whitespace(image)
    return core.orient_image(image, settings)


def render_dashboard_image(image: Image.Image, settings: Any, opts: dict[str, Any]) -> Image.Image:
    length_mode = str(opts.get("lengthMode", "auto"))
    fit = str(opts.get("fit", "full-width"))

    if length_mode != "fixed":
        image = crop_image(ImageOps.exif_transpose(image), opts)
        return core.prepare_image(image, settings)

    image = initial_grayscale(image, settings, opts)
    target_h = mm_to_px(float(opts.get("lengthMm", 50)), settings.dpi)

    if fit == "cover":
        ratio = max(core.WIDTH_PX / image.width, target_h / image.height)
    elif fit == "contain":
        ratio = min(core.WIDTH_PX / image.width, target_h / image.height)
    else:
        ratio = core.WIDTH_PX / image.width

    resized = image.resize(
        (max(1, round(image.width * ratio)), max(1, round(image.height * ratio))),
        Image.Resampling.LANCZOS,
    )
    canvas = Image.new("L", (core.WIDTH_PX, target_h), 255)
    x = (core.WIDTH_PX - resized.width) // 2
    y = (target_h - resized.height) // 2
    canvas.paste(resized, (x, y))
    if hasattr(core, "apply_tone"):
        canvas = core.apply_tone(canvas, settings)
    if hasattr(core, "binarize_image"):
        return core.binarize_image(canvas, settings)
    return core.prepare_image(canvas, settings)


def decode_data_url(value: str) -> bytes:
    if "," in value:
        value = value.split(",", 1)[1]
    return base64.b64decode(value)


def load_image_data_url(value: str) -> Image.Image:
    return Image.open(io.BytesIO(decode_data_url(value)))


def render_pdf_pages(pdf_bytes: bytes, opts: dict[str, Any]) -> list[Image.Image]:
    if not pdf_bytes.startswith(b"%PDF"):
        raise ValueError("file is not a PDF")

    from_page = max(1, int(opts.get("from", 1)))
    to_page = max(from_page, int(opts.get("to", 9999)))
    dpi = int(opts.get("dpi", 203))

    settings = core.Settings(dpi=dpi)

    with tempfile.TemporaryDirectory() as tmp:
        workdir = Path(tmp)
        source = workdir / "job.pdf"
        source.write_bytes(pdf_bytes)
        pages = core.render_pdf_or_ps(source, settings, workdir)

    if from_page > 1 or to_page < len(pages):
        pages = pages[from_page - 1:to_page]
    return pages


def page_payload(image: Image.Image, settings: Any) -> dict[str, Any]:
    return {
        "preview": png_data_url(image),
        "width": image.width,
        "height": image.height,
        "lengthMm": round(image.height / settings.dpi * 25.4, 1),
    }


def render_markdown_text(source: str, opts: dict[str, Any]) -> list[Image.Image]:
    md_opts = core.MarkdownOptions(
        font_size=int(opts.get("fontSize", 32)),
        align=str(opts.get("align", "left")),
        margin_x=int(opts.get("marginX", 8)),
        margin_y=int(opts.get("marginY", 8)),
        line_gap=int(opts.get("lineGap", 2)),
        paragraph_gap=int(opts.get("paragraphGap", 6)),
        list_indent=int(opts.get("listIndent", 12)),
        code_padding_x=int(opts.get("codePaddingX", 8)),
        code_padding_y=int(opts.get("codePaddingY", 6)),
        heading_h1_delta=int(opts.get("headingH1Delta", 14)),
        heading_h2_delta=int(opts.get("headingH2Delta", 10)),
        heading_h3_delta=int(opts.get("headingH3Delta", 6)),
        heading_h4_delta=int(opts.get("headingH4Delta", 4)),
        heading_h5_delta=int(opts.get("headingH5Delta", 2)),
        heading_h6_delta=0,
        content_width=int(opts.get("contentWidth", 0)),
        wrap=bool(opts.get("wrap", True)),
        hr_padding=int(opts.get("hrPadding", 8)),
        compact=bool(opts.get("compact", False)),
    )
    raster_settings = core.Settings(
        font_size=md_opts.font_size,
        align=md_opts.align,
        threshold=int(opts.get("threshold", 180)),
        dither=str(opts.get("dither", "floyd-steinberg")),
        invert=bool(opts.get("invert", False)),
    )
    image = core.render_markdown(source or " ", md_opts)
    if hasattr(core, "apply_tone"):
        image = core.apply_tone(image, raster_settings)
    if hasattr(core, "binarize_image"):
        image = core.binarize_image(image, raster_settings)
    return [image]


def render_pdf_for_preview(pdf_bytes: bytes, opts: dict[str, Any]) -> tuple[list[Image.Image], Any]:
    raw_pages = render_pdf_pages(pdf_bytes, opts)
    settings = settings_from_dashboard_opts(opts, raw_pages[0].width if raw_pages else 1)
    prepared: list[Image.Image] = []
    for page in raw_pages:
        image = page
        if settings.trim:
            image = core.trim_whitespace(image)
        image = core.orient_image(image, settings)
        if settings.scale == "fit-width" and image.width != core.WIDTH_PX:
            ratio = core.WIDTH_PX / image.width
            height = max(1, int(image.height * ratio))
            image = image.resize((core.WIDTH_PX, height), Image.Resampling.LANCZOS)
        if hasattr(core, "apply_tone"):
            image = core.apply_tone(image, settings)
        if hasattr(core, "binarize_image"):
            image = core.binarize_image(image, settings)
        else:
            image = core.prepare_image(image, settings)
        prepared.append(image)
    return prepared, settings


def settings_from_dashboard_opts(opts: dict[str, Any], fallback_dpi: int) -> Any:
    server = DashboardServer.__new__(DashboardServer)
    return core.Settings(
        addr=None,
        dpi=int(opts.get("dpi", fallback_dpi or 203)),
        dither=str(opts.get("dither", "floyd-steinberg")),
        threshold=int(opts.get("threshold", 180)),
        brightness=float(opts.get("brightness", 1.0)),
        contrast=float(opts.get("contrast", 1.0)),
        trim=bool(opts.get("trim", True)),
        orientation=str(opts.get("orientation", "auto")),
        scale=str(opts.get("fit", "fit-width")),
    )


class DashboardServer(ThreadingHTTPServer):
    def __init__(self, server_address, handler_class, printer_addr: str, channel: int):
        super().__init__(server_address, handler_class)
        self.printer_addr = printer_addr
        self.channel = channel


class Handler(BaseHTTPRequestHandler):
    server: DashboardServer

    def log_message(self, fmt: str, *args) -> None:
        print(fmt % args, file=sys.stderr)

    def do_GET(self) -> None:
        if self.path != "/":
            self.send_error(404)
            return
        body = HTML.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self) -> None:
        try:
            length = int(self.headers.get("Content-Length", "0"))
            if length > 60 * 1024 * 1024:
                raise ValueError("payload is too large")
            payload = json.loads(self.rfile.read(length))
            self.dispatch(payload)
        except Exception as exc:
            json_response(self, 400, {"error": str(exc)})

    def dispatch(self, payload: dict[str, Any]) -> None:
        opts = payload.get("settings") or {}
        warning = core_warning()
        if self.path == "/api/image/preview":
            settings = settings_from_payload(self.server, payload)
            image = load_image_data_url(payload["image"])
            prepared = render_dashboard_image(image, settings, opts)
            json_response(self, 200, {
                "pages": [page_payload(prepared, settings)],
                "raster": raster_summary(settings),
                "warning": warning,
            })
            return
        if self.path == "/api/image/print":
            settings = settings_from_payload(self.server, payload)
            image = load_image_data_url(payload["image"])
            prepared = render_dashboard_image(image, settings, opts)
            core.print_prepared_images([prepared], settings)
            json_response(self, 200, {
                "message": f"Printed {prepared.width} x {prepared.height} px",
            })
            return
        if self.path == "/api/pdf/preview":
            pdf_bytes = decode_data_url(payload["pdf"])
            prepared, settings = render_pdf_for_preview(pdf_bytes, opts)
            json_response(self, 200, {
                "pages": [page_payload(image, settings) for image in prepared],
                "raster": raster_summary(settings),
                "warning": warning,
            })
            return
        if self.path == "/api/pdf/print":
            pdf_bytes = decode_data_url(payload["pdf"])
            prepared, settings = render_pdf_for_preview(pdf_bytes, opts)
            full_settings = core.Settings(
                addr=self.server.printer_addr,
                channel=self.server.channel,
                darkness=int(opts.get("darkness", 9500)),
                speed=int(opts.get("speed", 10)),
                quality=3,
                threshold=settings.threshold,
                feed_lines=int(opts.get("feedLines", 60)),
                dither=settings.dither,
                dpi=settings.dpi,
                orientation=settings.orientation,
                trim=settings.trim,
            )
            core.print_prepared_images(prepared, full_settings)
            json_response(self, 200, {
                "message": f"Printed {len(prepared)} page{'s' if len(prepared) != 1 else ''}",
            })
            return
        if self.path == "/api/text/preview":
            source = str(opts.get("source", ""))
            images = render_markdown_text(source, opts)
            settings = core.Settings(
                font_size=int(opts.get("fontSize", 32)),
                align=str(opts.get("align", "left")),
                dither=str(opts.get("dither", "floyd-steinberg")),
                threshold=int(opts.get("threshold", 180)),
                invert=bool(opts.get("invert", False)),
            )
            json_response(self, 200, {
                "pages": [page_payload(image, settings) for image in images],
                "raster": raster_summary(settings),
                "warning": warning,
            })
            return
        if self.path == "/api/text/print":
            source = str(opts.get("source", ""))
            images = render_markdown_text(source, opts)
            settings = core.Settings(
                addr=self.server.printer_addr,
                channel=self.server.channel,
                darkness=int(opts.get("darkness", 9500)),
                speed=int(opts.get("speed", 10)),
                quality=3,
                font_size=int(opts.get("fontSize", 32)),
                align=str(opts.get("align", "left")),
                feed_lines=int(opts.get("feedLines", 60)),
                dither=str(opts.get("dither", "floyd-steinberg")),
                threshold=int(opts.get("threshold", 180)),
                invert=bool(opts.get("invert", False)),
            )
            core.print_prepared_images(images, settings)
            json_response(self, 200, {
                "message": f"Printed {images[0].width} x {images[0].height} px",
            })
            return
        self.send_error(404)


def main() -> int:
    parser = argparse.ArgumentParser(description="Run the X6H RFCOMM print dashboard.")
    parser.add_argument("--addr", default=None, help="Bluetooth MAC address")
    parser.add_argument("--channel", type=int, default=1)
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8765)
    args = parser.parse_args()

    if not args.addr:
        parser.error("--addr is required")

    server = DashboardServer((args.host, args.port), Handler, args.addr.replace("-", ":").upper(), args.channel)
    print(f"Serving http://{args.host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
