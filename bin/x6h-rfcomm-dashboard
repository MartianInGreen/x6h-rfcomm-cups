    function setImageCrop(next) {
      const minSize = 5;
      next.w = clamp(next.w, minSize, 100);
      next.h = clamp(next.h, minSize, 100);
      next.x = clamp(next.x, 0, 100 - next.w);
      next.y = clamp(next.y, 0, 100 - next.h);
      imageCrop = next;
      renderImageCrop();
      scheduleImagePreview();
    }

    function renderImageCrop() {
      const host = $("imageCropper").getBoundingClientRect();
      const img = $("imageCropImage").getBoundingClientRect();
      const left = img.left - host.left + img.width * imageCrop.x / 100;
      const top = img.top - host.top + img.height * imageCrop.y / 100;
      const box = $("imageCropBox");
      box.style.left = `${left}px`;
      box.style.top = `${top}px`;
      box.style.width = `${img.width * imageCrop.w / 100}px`;
      box.style.height = `${img.height * imageCrop.h / 100}px`;
    }

    function imageCropDrag(event) {
      if (!imageDrag) return;
      const img = $("imageCropImage").getBoundingClientRect();
      const dx = (event.clientX - imageDrag.startX) / img.width * 100;
      const dy = (event.clientY - imageDrag.startY) / img.height * 100;
      const start = imageDrag.startCrop;
      const next = { ...start };
      const minSize = 5;
      if (imageDrag.handle === "move") {
        next.x = start.x + dx;
        next.y = start.y + dy;
      } else {
        if (imageDrag.handle.includes("w")) {
          const right = start.x + start.w;
          next.x = clamp(start.x + dx, 0, right - minSize);
          next.w = right - next.x;
        }
        if (imageDrag.handle.includes("e")) {
          next.w = clamp(start.w + dx, minSize, 100 - start.x);
        }
        if (imageDrag.handle.includes("n")) {
          const bottom = start.y + start.h;
          next.y = clamp(start.y + dy, 0, bottom - minSize);
          next.h = bottom - next.y;
        }
        if (imageDrag.handle.includes("s")) {
          next.h = clamp(start.h + dy, minSize, 100 - start.y);
        }
      }
      setImageCrop(next);
    }

    $("imageCropBox").addEventListener("pointerdown", event => {
      event.preventDefault();
      const handle = event.target.dataset.handle || "move";
      imageDrag = { handle, startX: event.clientX, startY: event.clientY, startCrop: { ...imageCrop } };
      $("imageCropBox").setPointerCapture(event.pointerId);
    });
    $("imageCropBox").addEventListener("pointermove", imageCropDrag);
    $("imageCropBox").addEventListener("pointerup", event => {
      imageDrag = null;
      $("imageCropBox").releasePointerCapture(event.pointerId);
    });
    $("imageCropBox").addEventListener("pointercancel", () => { imageDrag = null; });
    $("imageResetCrop").addEventListener("click", () => setImageCrop({ x: 0, y: 0, w: 100, h: 100 }));
    $("imageCropImage").addEventListener("load", renderImageCrop);
    window.addEventListener("resize", renderImageCrop);

