#!/usr/bin/env python3
"""Small local web UI for X6H RFCOMM image printing."""
from __future__ import annotations

import argparse
import base64
import dataclasses
import importlib.machinery
import importlib.util
import io
import json
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any

from PIL import Image, ImageOps


def load_core():
    path = Path(__file__).with_name("x6h-rfcomm-print")
    loader = importlib.machinery.SourceFileLoader("x6h_rfcomm_print", str(path))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("could not load printer core")
    module = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = module
    loader.exec_module(module)
    return module


core = load_core()
CORE_FIELDS = {field.name for field in dataclasses.fields(core.Settings)}
REQUIRED_RASTER_FIELDS = {
    "dither",
    "dither_strength",
    "ordered_size",
    "serpentine",
    "brightness",
    "contrast",
    "gamma",
    "invert",
}


