    function readImageFile(file, label) {
      const reader = new FileReader();
      reader.onload = () => loadImageData(reader.result, label);
      reader.readAsDataURL(file);
    }

    $("imageFile").addEventListener("change", () => {
      const file = $("imageFile").files[0];
