  <script>
    const ids = [
      "file", "fileName", "status", "paper", "previewMeta", "addrMeta",
      "lengthMode", "lengthMm", "fit", "orientation", "trim", "dither",
      "cropper", "cropImage", "cropBox", "resetCrop",
      "ditherStrength", "ditherStrengthNumber", "orderedSize", "serpentine",
      "brightness", "brightnessNumber", "contrast", "contrastNumber",
      "gamma", "gammaNumber", "invert",
      "threshold", "thresholdNumber", "darkness", "darknessNumber",
      "speed", "speedNumber", "feedLines", "feedLinesNumber",
      "previewBtn", "printBtn"
    ];
    const el = Object.fromEntries(ids.map(id => [id, document.getElementById(id)]));
    let imageData = null;
    let debounce = null;
    let crop = { x: 0, y: 0, w: 100, h: 100 };
    let drag = null;

    function bindPair(a, b) {
      el[a].addEventListener("input", () => { el[b].value = el[a].value; schedulePreview(); });
      el[b].addEventListener("input", () => { el[a].value = el[b].value; schedulePreview(); });
    }

    bindPair("threshold", "thresholdNumber");
    bindPair("ditherStrength", "ditherStrengthNumber");
    bindPair("brightness", "brightnessNumber");
    bindPair("contrast", "contrastNumber");
    bindPair("gamma", "gammaNumber");
    bindPair("darkness", "darknessNumber");
    bindPair("speed", "speedNumber");
    bindPair("feedLines", "feedLinesNumber");

    ["lengthMode", "lengthMm", "fit", "orientation", "trim", "dither", "orderedSize", "serpentine", "invert"].forEach(id => {
      el[id].addEventListener("input", schedulePreview);
      el[id].addEventListener("change", schedulePreview);
    });

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function setCrop(next) {
      const minSize = 5;
      next.w = clamp(next.w, minSize, 100);
      next.h = clamp(next.h, minSize, 100);
      next.x = clamp(next.x, 0, 100 - next.w);
      next.y = clamp(next.y, 0, 100 - next.h);
      crop = next;
      renderCrop();
      schedulePreview();
    }

    function renderCrop() {
      const host = el.cropper.getBoundingClientRect();
      const image = el.cropImage.getBoundingClientRect();
      const left = image.left - host.left + image.width * crop.x / 100;
      const top = image.top - host.top + image.height * crop.y / 100;
      el.cropBox.style.left = `${left}px`;
      el.cropBox.style.top = `${top}px`;
      el.cropBox.style.width = `${image.width * crop.w / 100}px`;
      el.cropBox.style.height = `${image.height * crop.h / 100}px`;
    }

    function cropFromDrag(event) {
      if (!drag) return;
      const image = el.cropImage.getBoundingClientRect();
      const dx = (event.clientX - drag.startX) / image.width * 100;
      const dy = (event.clientY - drag.startY) / image.height * 100;
      const start = drag.startCrop;
      const next = { ...start };
      const minSize = 5;

      if (drag.handle === "move") {
        next.x = start.x + dx;
        next.y = start.y + dy;
      } else {
        if (drag.handle.includes("w")) {
          const right = start.x + start.w;
          next.x = clamp(start.x + dx, 0, right - minSize);
          next.w = right - next.x;
        }
        if (drag.handle.includes("e")) {
          next.w = clamp(start.w + dx, minSize, 100 - start.x);
        }
        if (drag.handle.includes("n")) {
          const bottom = start.y + start.h;
          next.y = clamp(start.y + dy, 0, bottom - minSize);
          next.h = bottom - next.y;
        }
        if (drag.handle.includes("s")) {
          next.h = clamp(start.h + dy, minSize, 100 - start.y);
        }
      }
      setCrop(next);
    }

    el.cropBox.addEventListener("pointerdown", event => {
      event.preventDefault();
      const handle = event.target.dataset.handle || "move";
      drag = {
        handle,
        startX: event.clientX,
        startY: event.clientY,
        startCrop: { ...crop }
      };
      el.cropBox.setPointerCapture(event.pointerId);
    });
    el.cropBox.addEventListener("pointermove", cropFromDrag);
    el.cropBox.addEventListener("pointerup", event => {
      drag = null;
      el.cropBox.releasePointerCapture(event.pointerId);
    });
    el.cropBox.addEventListener("pointercancel", () => { drag = null; });
    el.resetCrop.addEventListener("click", () => setCrop({ x: 0, y: 0, w: 100, h: 100 }));
    el.cropImage.addEventListener("load", renderCrop);
    window.addEventListener("resize", renderCrop);

    function loadImageData(dataUrl, label) {
      imageData = dataUrl;
      el.fileName.textContent = label;
      el.cropImage.src = imageData;
      el.cropper.classList.remove("hidden");
      setCrop({ x: 0, y: 0, w: 100, h: 100 });
      el.printBtn.disabled = false;
      preview();
    }

    function readImageFile(file, label) {
      const reader = new FileReader();
      reader.onload = () => {
        loadImageData(reader.result, label);
      };
      reader.readAsDataURL(file);
    }

    el.file.addEventListener("change", () => {
      const file = el.file.files[0];
      if (!file) return;
      readImageFile(file, file.name);
    });

    window.addEventListener("paste", event => {
      const items = Array.from(event.clipboardData?.items || []);
      const imageItem = items.find(item => item.kind === "file" && item.type.startsWith("image/"));
      if (!imageItem) return;
      const file = imageItem.getAsFile();
      if (!file) return;
      event.preventDefault();
      readImageFile(file, "Pasted image");
    });

    el.previewBtn.addEventListener("click", preview);
    el.printBtn.addEventListener("click", printImage);

    function settings() {
      return {
        lengthMode: el.lengthMode.value,
        lengthMm: Number(el.lengthMm.value),
        fit: el.fit.value,
        orientation: el.orientation.value,
        trim: el.trim.checked,
        cropLeft: crop.x,
        cropRight: 100 - crop.x - crop.w,
        cropTop: crop.y,
        cropBottom: 100 - crop.y - crop.h,
        dither: el.dither.value,
        ditherStrength: Number(el.ditherStrength.value),
        orderedSize: Number(el.orderedSize.value),
        serpentine: el.serpentine.checked,
        threshold: Number(el.threshold.value),
        brightness: Number(el.brightness.value),
        contrast: Number(el.contrast.value),
        gamma: Number(el.gamma.value),
        invert: el.invert.checked,
        darkness: Number(el.darkness.value),
        speed: Number(el.speed.value),
        feedLines: Number(el.feedLines.value)
      };
    }

    function schedulePreview() {
      if (!imageData) return;
      clearTimeout(debounce);
      debounce = setTimeout(preview, 180);
    }

    async function request(path) {
      const response = await fetch(path, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image: imageData, settings: settings() })
      });
      const body = await response.json();
      if (!response.ok) throw new Error(body.error || "Request failed");
      return body;
    }

    async function preview() {
      if (!imageData) return;
      el.status.textContent = "Rendering";
      el.status.className = "status";
      try {
        const body = await request("/api/preview");
        el.paper.innerHTML = `<img alt="Print preview" src="${body.preview}">`;
        el.previewMeta.textContent = `${body.width} x ${body.height} px / ${body.lengthMm} mm`;
        el.addrMeta.textContent = body.raster || body.addr;
        el.status.textContent = body.warning || "Ready";
        el.status.className = body.warning ? "status error" : "status";
      } catch (error) {
        el.status.textContent = error.message;
        el.status.className = "status error";
      }
    }

    async function printImage() {
      if (!imageData) return;
      el.printBtn.disabled = true;
      el.status.textContent = "Printing";
      el.status.className = "status";
      try {
        const body = await request("/api/print");
        el.status.textContent = body.message;
      } catch (error) {
        el.status.textContent = error.message;
        el.status.className = "status error";
      } finally {
        el.printBtn.disabled = false;
      }
    }
  </script>
</body>
</html>
"""


def image_from_data_url(value: str) -> Image.Image:
    if "," in value:
        value = value.split(",", 1)[1]
    data = base64.b64decode(value)
    return Image.open(io.BytesIO(data))


def json_response(handler: BaseHTTPRequestHandler, status: int, payload: dict[str, Any]) -> None:
    body = json.dumps(payload).encode()
    handler.send_response(status)
    handler.send_header("Content-Type", "application/json")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)


def png_data_url(image: Image.Image) -> str:
    buf = io.BytesIO()
    image.convert("L").save(buf, format="PNG")
    return "data:image/png;base64," + base64.b64encode(buf.getvalue()).decode()


def mm_to_px(mm: float, dpi: int) -> int:
    return max(1, round(mm / 25.4 * dpi))


def settings_from_payload(server: "DashboardServer", payload: dict[str, Any]) -> Any:
    opts = payload.get("settings") or {}
    kwargs = dict(
        addr=server.printer_addr,
        channel=server.channel,
        darkness=int(opts.get("darkness", 9500)),
        speed=int(opts.get("speed", 10)),
        quality=3,
        threshold=int(opts.get("threshold", 180)),
        feed_lines=int(opts.get("feedLines", 60)),
        scale="fit-width",
        dither=str(opts.get("dither", "floyd-steinberg")),
        dither_strength=float(opts.get("ditherStrength", 1.0)),
        ordered_size=4 if int(opts.get("orderedSize", 8)) <= 4 else 8,
        serpentine=bool(opts.get("serpentine", True)),
        brightness=float(opts.get("brightness", 1.0)),
        contrast=float(opts.get("contrast", 1.0)),
        gamma=float(opts.get("gamma", 1.0)),
        invert=bool(opts.get("invert", False)),
        orientation=str(opts.get("orientation", "auto")),
        trim=bool(opts.get("trim", True)),
    )
    return core.Settings(**{key: value for key, value in kwargs.items() if key in CORE_FIELDS})


def core_warning() -> str | None:
    missing = sorted(REQUIRED_RASTER_FIELDS - CORE_FIELDS)
    if missing:
        return "Older printer core loaded; rerun the installer so raster controls apply."
    return None


def raster_summary(settings: Any) -> str:
    dither = getattr(settings, "dither", "none")
    threshold = getattr(settings, "threshold", 180)
    strength = getattr(settings, "dither_strength", 1.0)
    if dither in {"none", "threshold"}:
        return f"no dither, threshold {threshold}"
    if dither == "grayscale":
        return "4-bit grayscale"
    return f"{dither}, threshold {threshold}, strength {strength}"


def crop_image(image: Image.Image, opts: dict[str, Any]) -> Image.Image:
    left_pct = max(0.0, min(45.0, float(opts.get("cropLeft", 0)))) / 100
    right_pct = max(0.0, min(45.0, float(opts.get("cropRight", 0)))) / 100
    top_pct = max(0.0, min(45.0, float(opts.get("cropTop", 0)))) / 100
    bottom_pct = max(0.0, min(45.0, float(opts.get("cropBottom", 0)))) / 100
    left = round(image.width * left_pct)
    right = image.width - round(image.width * right_pct)
    top = round(image.height * top_pct)
    bottom = image.height - round(image.height * bottom_pct)
    if right <= left or bottom <= top:
        return image
    return image.crop((left, top, right, bottom))


def initial_grayscale(image: Image.Image, settings: Any, opts: dict[str, Any]) -> Image.Image:
    image = ImageOps.exif_transpose(image).convert("L")
    image = crop_image(image, opts)
    if settings.trim:
        image = core.trim_whitespace(image)
    return core.orient_image(image, settings)


def render_dashboard_image(image: Image.Image, settings: Any, opts: dict[str, Any]) -> Image.Image:
    length_mode = str(opts.get("lengthMode", "auto"))
    fit = str(opts.get("fit", "full-width"))

    if length_mode != "fixed":
        image = crop_image(ImageOps.exif_transpose(image), opts)
        return core.prepare_image(image, settings)

    image = initial_grayscale(image, settings, opts)
    target_h = mm_to_px(float(opts.get("lengthMm", 50)), settings.dpi)

    if fit == "cover":
        ratio = max(core.WIDTH_PX / image.width, target_h / image.height)
    elif fit == "contain":
        ratio = min(core.WIDTH_PX / image.width, target_h / image.height)
    else:
        ratio = core.WIDTH_PX / image.width

    resized = image.resize(
        (max(1, round(image.width * ratio)), max(1, round(image.height * ratio))),
        Image.Resampling.LANCZOS,
    )
    canvas = Image.new("L", (core.WIDTH_PX, target_h), 255)
    x = (core.WIDTH_PX - resized.width) // 2
    y = (target_h - resized.height) // 2
    canvas.paste(resized, (x, y))
    if hasattr(core, "apply_tone"):
        canvas = core.apply_tone(canvas, settings)
    if hasattr(core, "binarize_image"):
        return core.binarize_image(canvas, settings)
    return core.prepare_image(canvas, settings)


class DashboardServer(ThreadingHTTPServer):
    def __init__(self, server_address, handler_class, printer_addr: str, channel: int):
        super().__init__(server_address, handler_class)
        self.printer_addr = printer_addr
        self.channel = channel


class Handler(BaseHTTPRequestHandler):
    server: DashboardServer

    def log_message(self, fmt: str, *args) -> None:
        print(fmt % args, file=sys.stderr)

    def do_GET(self) -> None:
        if self.path != "/":
            self.send_error(404)
            return
        body = HTML.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self) -> None:
        try:
            length = int(self.headers.get("Content-Length", "0"))
            if length > 25 * 1024 * 1024:
                raise ValueError("image is too large")
            payload = json.loads(self.rfile.read(length))
            opts = payload.get("settings") or {}
            settings = settings_from_payload(self.server, payload)
            image = image_from_data_url(payload["image"])
            prepared = render_dashboard_image(image, settings, opts)

            if self.path == "/api/preview":
                json_response(self, 200, {
                    "preview": png_data_url(prepared),
                    "width": prepared.width,
                    "height": prepared.height,
                    "lengthMm": round(prepared.height / settings.dpi * 25.4, 1),
                    "addr": settings.addr,
                    "raster": raster_summary(settings),
                    "warning": core_warning(),
                })
                return

            if self.path == "/api/print":
                core.print_prepared_images([prepared], settings)
                json_response(self, 200, {
                    "message": "Printed",
                    "width": prepared.width,
                    "height": prepared.height,
                })
                return

            self.send_error(404)
        except Exception as exc:
            json_response(self, 400, {"error": str(exc)})


def main() -> int:
    parser = argparse.ArgumentParser(description="Run the X6H RFCOMM print dashboard.")
    parser.add_argument("--addr", default=None, help="Bluetooth MAC address")
    parser.add_argument("--channel", type=int, default=1)
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8765)
    args = parser.parse_args()

    if not args.addr:
        parser.error("--addr is required")

    server = DashboardServer((args.host, args.port), Handler, args.addr.replace("-", ":").upper(), args.channel)
    print(f"Serving http://{args.host}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
