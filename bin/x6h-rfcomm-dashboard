      </div>

      <div class="group">
        <div class="group-title">Printer</div>
        <div class="row">
          <label>Darkness <input id="darkness" type="range" min="6000" max="14000" step="250" value="9500"></label>
          <input id="darknessNumber" type="number" min="6000" max="14000" step="250" value="9500">
        </div>
        <div class="row">
          <label>Speed <input id="speed" type="range" min="4" max="16" value="10"></label>
          <input id="speedNumber" type="number" min="4" max="16" value="10">
        </div>
        <div class="row">
          <label>Feed lines <input id="feedLines" type="range" min="0" max="160" value="60"></label>
          <input id="feedLinesNumber" type="number" min="0" max="160" value="60">
        </div>
      </div>

      <div class="actions">
        <button id="previewBtn">Preview</button>
        <button id="printBtn" class="primary" disabled>Print</button>
      </div>
    </section>

    <section class="panel preview-wrap">
      <div class="preview-head">
        <span id="previewMeta">384 px print width</span>
        <span id="addrMeta"></span>
      </div>
      <div class="preview-stage">
        <div class="paper" id="paper"><div class="empty">Select an image</div></div>
      </div>
