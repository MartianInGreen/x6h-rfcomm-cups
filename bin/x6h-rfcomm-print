#!/usr/bin/env python3
"""Print to X6H-style Bluetooth thermal printers over RFCOMM/SPP.

The executable works in two modes:

* CLI mode:
    x6h-rfcomm-print --addr B7:2C:83:E6:F8:3E "Hello"
    x6h-rfcomm-print --addr B7:2C:83:E6:F8:3E --file receipt.pdf

* CUPS backend mode:
    install this file as /usr/lib/cups/backend/x6h-rfcomm and create a raw
    queue with a URI like x6h-rfcomm://B7-2C-83-E6-F8-3E?channel=1
"""
from __future__ import annotations

import argparse
import os
import re
import shlex
import socket
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass, replace
from pathlib import Path
from urllib.parse import parse_qs, urlparse

from PIL import Image, ImageDraw, ImageEnhance, ImageFont, ImageOps, UnidentifiedImageError

try:
    import lzo
except ImportError:
    lzo = None

try:
    import markdown as _markdown
except ImportError:
    _markdown = None

WIDTH_BYTES = 48
WIDTH_PX = WIDTH_BYTES * 8

CRC8_TABLE = [
    0x00, 0x07, 0x0E, 0x09, 0x1C, 0x1B, 0x12, 0x15, 0x38, 0x3F, 0x36, 0x31, 0x24, 0x23, 0x2A, 0x2D,
    0x70, 0x77, 0x7E, 0x79, 0x6C, 0x6B, 0x62, 0x65, 0x48, 0x4F, 0x46, 0x41, 0x54, 0x53, 0x5A, 0x5D,
    0xE0, 0xE7, 0xEE, 0xE9, 0xFC, 0xFB, 0xF2, 0xF5, 0xD8, 0xDF, 0xD6, 0xD1, 0xC4, 0xC3, 0xCA, 0xCD,
    0x90, 0x97, 0x9E, 0x99, 0x8C, 0x8B, 0x82, 0x85, 0xA8, 0xAF, 0xA6, 0xA1, 0xB4, 0xB3, 0xBA, 0xBD,
    0xC7, 0xC0, 0xC9, 0xCE, 0xDB, 0xDC, 0xD5, 0xD2, 0xFF, 0xF8, 0xF1, 0xF6, 0xE3, 0xE4, 0xED, 0xEA,
    0xB7, 0xB0, 0xB9, 0xBE, 0xAB, 0xAC, 0xA5, 0xA2, 0x8F, 0x88, 0x81, 0x86, 0x93, 0x94, 0x9D, 0x9A,
    0x27, 0x20, 0x29, 0x2E, 0x3B, 0x3C, 0x35, 0x32, 0x1F, 0x18, 0x11, 0x16, 0x03, 0x04, 0x0D, 0x0A,
    0x57, 0x50, 0x59, 0x5E, 0x4B, 0x4C, 0x45, 0x42, 0x6F, 0x68, 0x61, 0x66, 0x73, 0x74, 0x7D, 0x7A,
    0x89, 0x8E, 0x87, 0x80, 0x95, 0x92, 0x9B, 0x9C, 0xB1, 0xB6, 0xBF, 0xB8, 0xAD, 0xAA, 0xA3, 0xA4,
    0xF9, 0xFE, 0xF7, 0xF0, 0xE5, 0xE2, 0xEB, 0xEC, 0xC1, 0xC6, 0xCF, 0xC8, 0xDD, 0xDA, 0xD3, 0xD4,
    0x69, 0x6E, 0x67, 0x60, 0x75, 0x72, 0x7B, 0x7C, 0x51, 0x56, 0x5F, 0x58, 0x4D, 0x4A, 0x43, 0x44,
    0x19, 0x1E, 0x17, 0x10, 0x05, 0x02, 0x0B, 0x0C, 0x21, 0x26, 0x2F, 0x28, 0x3D, 0x3A, 0x33, 0x34,
    0x4E, 0x49, 0x40, 0x47, 0x52, 0x55, 0x5C, 0x5B, 0x76, 0x71, 0x78, 0x7F, 0x6A, 0x6D, 0x64, 0x63,
    0x3E, 0x39, 0x30, 0x37, 0x22, 0x25, 0x2C, 0x2B, 0x06, 0x01, 0x08, 0x0F, 0x1A, 0x1D, 0x14, 0x13,
    0xAE, 0xA9, 0xA0, 0xA7, 0xB2, 0xB5, 0xBC, 0xBB, 0x96, 0x91, 0x98, 0x9F, 0x8A, 0x8D, 0x84, 0x83,
    0xDE, 0xD9, 0xD0, 0xD7, 0xC2, 0xC5, 0xCC, 0xCB, 0xE6, 0xE1, 0xE8, 0xEF, 0xFA, 0xFD, 0xF4, 0xF3,
]


@dataclass(frozen=True)
class Settings:
    addr: str | None = None
    channel: int = 1
    darkness: int = 9500
    speed: int = 10
    quality: int = 3
    threshold: int = 180
    font_size: int = 32
    feed_lines: int = 80
    align: str = "left"
    scale: str = "fit-width"
    dither: str = "none"
    dither_strength: float = 1.0
    ordered_size: int = 8
    serpentine: bool = True
    brightness: float = 1.0
    contrast: float = 1.0
    gamma: float = 1.0
    invert: bool = False
    orientation: str = "auto"
    trim: bool = True
    dpi: int = 203
    line_delay: float = 0.008


@dataclass(frozen=True)
class MarkdownOptions:
    font_size: int = 32
    align: str = "left"
    margin_x: int = 8
    margin_y: int = 8
    line_gap: int = 2
    paragraph_gap: int = 6
    list_indent: int = 12
    code_padding_x: int = 8
    code_padding_y: int = 6
    heading_h1_delta: int = 14
    heading_h2_delta: int = 10
    heading_h3_delta: int = 6
    heading_h4_delta: int = 4
    heading_h5_delta: int = 2
    heading_h6_delta: int = 0
    content_width: int = 0
    wrap: bool = True
    hr_padding: int = 8
    compact: bool = False


def cups_log(level: str, message: str) -> None:
    print(f"{level}: {message}", file=sys.stderr)


def crc8(data: bytes) -> int:
    crc = 0
    for byte in data:
        crc = CRC8_TABLE[(crc ^ byte) & 0xFF]
    return crc & 0xFF


def frame(command: int, payload: bytes = b"") -> bytes:
    if len(payload) > 0xFFFF:
        raise ValueError("payload too large")
    return (
        bytes([0x51, 0x78, command & 0xFF, 0x00])
        + len(payload).to_bytes(2, "little")
        + payload
        + bytes([crc8(payload), 0xFF])
    )


def parse_bool(value: str) -> bool:
    return value.strip().lower() in {"1", "true", "yes", "on"}


def parse_int_choice(value: str) -> int:
    match = re.search(r"\d+", value)
    if not match:
        raise ValueError(f"expected a numeric option value, got {value!r}")
    return int(match.group(0))


def parse_device_uri(uri: str, settings: Settings) -> Settings:
    if not uri:
        return settings

    parsed = urlparse(uri)
    query = {k: v[-1] for k, v in parse_qs(parsed.query).items() if v}
    raw_addr = parsed.netloc or parsed.path.lstrip("/")
    raw_addr = raw_addr.split("/")[0]
    if raw_addr:
        raw_addr = raw_addr.replace("-", ":").upper()
        if re.fullmatch(r"[0-9A-F]{2}(:[0-9A-F]{2}){5}", raw_addr):
            settings = replace(settings, addr=raw_addr)

    for key, value in query.items():
        settings = apply_option(settings, key, value)
    return settings


def apply_option(settings: Settings, key: str, value: str) -> Settings:
    normalized = key.lower().replace("_", "-")
    if normalized.startswith("x6h-"):
        normalized = normalized[4:]
    value_normalized = value.lower().replace("_", "-")

    if normalized in {"addr", "address"}:
        return replace(settings, addr=value.replace("-", ":").upper())
    if normalized == "channel":
        return replace(settings, channel=parse_int_choice(value))
    if normalized in {"darkness", "energy"}:
        return replace(settings, darkness=parse_int_choice(value))
    if normalized == "speed":
        return replace(settings, speed=parse_int_choice(value))
    if normalized == "quality":
        return replace(settings, quality=parse_int_choice(value))
    if normalized == "threshold":
        return replace(settings, threshold=parse_int_choice(value))
    if normalized in {"font-size", "fontsize"}:
        return replace(settings, font_size=parse_int_choice(value))
    if normalized in {"feed-lines", "feedlines", "feed"}:
        return replace(settings, feed_lines=parse_int_choice(value))
    if normalized == "align" and value in {"left", "center", "right"}:
        return replace(settings, align=value)
    if normalized == "scale" and value in {"fit-width", "native"}:
        return replace(settings, scale=value)
    if normalized == "dither" and value_normalized in {"grayscale", "none", "threshold", "floyd-steinberg", "ordered", "atkinson"}:
        return replace(settings, dither=value_normalized)
    if normalized in {"dither-strength", "ditherstrength"}:
        return replace(settings, dither_strength=max(0.0, min(1.5, float(value))))
    if normalized in {"ordered-size", "orderedsize"}:
        return replace(settings, ordered_size=4 if parse_int_choice(value) <= 4 else 8)
    if normalized == "serpentine":
        return replace(settings, serpentine=parse_bool(value))
    if normalized == "brightness":
        return replace(settings, brightness=max(0.1, min(3.0, float(value))))
    if normalized == "contrast":
        return replace(settings, contrast=max(0.1, min(3.0, float(value))))
    if normalized == "gamma":
        return replace(settings, gamma=max(0.2, min(3.0, float(value))))
    if normalized == "invert":
        return replace(settings, invert=parse_bool(value))
    if normalized in {"orientation", "imageorientation", "image-orientation"}:
        orientation_values = {
            "auto": "auto",
            "as-is": "as-is",
            "asis": "as-is",
            "rotate-cw": "rotate-cw",
            "rotatecw": "rotate-cw",
            "rotate-ccw": "rotate-ccw",
            "rotateccw": "rotate-ccw",
        }
        if value_normalized in orientation_values:
            return replace(settings, orientation=orientation_values[value_normalized])
    if normalized == "trim":
        return replace(settings, trim=parse_bool(value))
    if normalized == "dpi":
        return replace(settings, dpi=int(value))
    if normalized == "line-delay":
        return replace(settings, line_delay=float(value))
    if normalized == "fit-width":
        return replace(settings, scale="fit-width" if parse_bool(value) else "native")
    return settings


def parse_cups_options(options: str, settings: Settings) -> Settings:
    for token in shlex.split(options or ""):
        if "=" in token:
            key, value = token.split("=", 1)
            settings = apply_option(settings, key, value)
    return settings


def find_font(size: int) -> ImageFont.FreeTypeFont | ImageFont.ImageFont:
    for path in (
        "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
        "/usr/share/fonts/TTF/DejaVuSans.ttf",
        "/usr/share/fonts/TTF/DejaVuSans-Bold.ttf",
    ):
        if os.path.exists(path):
            return ImageFont.truetype(path, size)
    return ImageFont.load_default()


def wrap_text(text: str, draw: ImageDraw.ImageDraw, font: ImageFont.ImageFont, max_width: int) -> list[str]:
    lines: list[str] = []
    for raw_line in text.splitlines() or [""]:
        words = raw_line.split()
        if not words:
            lines.append("")
            continue
        current = words[0]
        for word in words[1:]:
            candidate = f"{current} {word}"
            if draw.textbbox((0, 0), candidate, font=font)[2] <= max_width:
                current = candidate
            else:
                lines.append(current)
                current = word
        lines.append(current)
    return lines


def render_text(text: str, settings: Settings) -> Image.Image:
    font = find_font(settings.font_size)
    probe = Image.new("L", (1, 1), 255)
    draw = ImageDraw.Draw(probe)
    margin = 8
    lines = wrap_text(text, draw, font, WIDTH_PX - margin * 2)
    bboxes = [draw.textbbox((0, 0), line or " ", font=font) for line in lines]
    line_heights = [max(1, box[3] - box[1]) for box in bboxes]
    height = sum(line_heights) + (len(lines) - 1) * 8 + margin * 2
    image = Image.new("L", (WIDTH_PX, height), 255)
    draw = ImageDraw.Draw(image)
    y = margin
    for line, box, line_height in zip(lines, bboxes, line_heights):
        width = box[2] - box[0]
        if settings.align == "center":
            x = max(margin, (WIDTH_PX - width) // 2)
        elif settings.align == "right":
            x = max(margin, WIDTH_PX - width - margin)
        else:
            x = margin
        draw.text((x - box[0], y - box[1]), line, fill=0, font=font)
        y += line_height + 8
    return image


def render_pdf_or_ps(path: Path, settings: Settings, workdir: Path) -> list[Image.Image]:
    output_prefix = workdir / "page"
    if path.read_bytes().startswith(b"%PDF"):
        command = ["pdftoppm", "-png", "-r", str(settings.dpi), str(path), str(output_prefix)]
    else:
        command = [
            "gs",
            "-dSAFER",
            "-dBATCH",
            "-dNOPAUSE",
            "-sDEVICE=pnggray",
            "-r" + str(settings.dpi),
            f"-sOutputFile={output_prefix}-%03d.png",
            str(path),
        ]
    try:
        subprocess.run(command, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    except FileNotFoundError as exc:
        tool = command[0]
        raise RuntimeError(f"{tool} is required to print PDF/PostScript jobs") from exc
    except subprocess.CalledProcessError as exc:
        raise RuntimeError(exc.stderr.decode(errors="replace").strip() or "document conversion failed") from exc

    pages = sorted(workdir.glob("page*.png"))
    if not pages:
        raise RuntimeError("document conversion produced no pages")
    return [Image.open(page).convert("L") for page in pages]


def image_from_bytes(data: bytes, settings: Settings) -> list[Image.Image]:
    if data.startswith(b"%PDF") or data.startswith(b"%!PS"):
        with tempfile.TemporaryDirectory() as tmp:
            workdir = Path(tmp)
            source = workdir / ("job.pdf" if data.startswith(b"%PDF") else "job.ps")
            source.write_bytes(data)
            return render_pdf_or_ps(source, settings, workdir)

    try:
        with tempfile.NamedTemporaryFile(suffix=".input") as handle:
            handle.write(data)
            handle.flush()
            return [Image.open(handle.name).convert("L")]
    except UnidentifiedImageError:
        text = data.decode("utf-8", errors="replace")
        return [render_text(text, settings)]


_MD_INLINE_RE = re.compile(
    r"(\*\*[^*]+\*\*|__[^_]+__|`[^`]+`|\[[^\]]+\]\([^)]+\)|\*[^*]+\*|_[^_]+_)"
)
_MD_HEADING_RE = re.compile(r"^(#{1,6})\s+(.*)$")
_MD_FENCE_RE = re.compile(r"^```")
_MD_HR_RE = re.compile(r"^\s*([-*_])\s*\1\s*\1[\s\1]*$")
_MD_BQ_RE = re.compile(r"^>\s?(.*)$")
_MD_ULI_RE = re.compile(r"^(\s*)[-*+]\s+(.*)$")
_MD_OLI_RE = re.compile(r"^(\s*)(\d+)\.\s+(.*)$")
_MD_CODE_RE = re.compile(r"`([^`]+)`")
_MD_BOLD_RE = re.compile(r"(\*\*[^*]+\*\*|__[^_]+__)")
_MD_ITALIC_RE = re.compile(r"(\*[^*]+\*|_[^_]+_)")


def _wrap_to_width(text: str, draw: ImageDraw.ImageDraw, font: ImageFont.ImageFont, max_width: int) -> list[str]:
    out: list[str] = []
    for raw in text.splitlines() or [""]:
        if not raw:
            out.append("")
            continue
        words = raw.split(" ")
        if not words:
            out.append("")
            continue
        current = words[0]
        for word in words[1:]:
            candidate = f"{current} {word}" if current else word
            if draw.textlength(candidate, font=font) <= max_width:
                current = candidate
            else:
                if current:
                    out.append(current)
                current = word
        if current:
            out.append(current)
    return out


def _inline_segments(text: str) -> list[tuple[str, dict[str, bool]]]:
    segments: list[tuple[str, dict[str, bool]]] = []
    pos = 0
    for match in _MD_INLINE_RE.finditer(text):
        if match.start() > pos:
            segments.append((text[pos:match.start()], {}))
        token = match.group(0)
        if token.startswith("**") or token.startswith("__"):
            segments.append((token[2:-2], {"bold": True}))
        elif token.startswith("`"):
            segments.append((token[1:-1], {"code": True}))
        elif token.startswith("["):
            label_match = re.match(r"\[([^\]]+)\]\(([^)]+)\)", token)
            if label_match:
                segments.append((label_match.group(1), {"link": True}))
            else:
                segments.append((token, {}))
        elif token.startswith("*") or token.startswith("_"):
            segments.append((token[1:-1], {"italic": True}))
        pos = match.end()
    if pos < len(text):
        segments.append((text[pos:], {}))
    if not segments:
        segments = [("", {})]
    return segments


def _font_for(
    base_font: ImageFont.FreeTypeFont | ImageFont.ImageFont,
    size_delta: int,
    bold: bool = False,
    italic: bool = False,
    monospace: bool = False,
) -> ImageFont.FreeTypeFont | ImageFont.ImageFont:
    if not isinstance(base_font, ImageFont.FreeTypeFont):
        return base_font
    size = max(8, base_font.size + size_delta)
    paths: list[tuple[str, ...]] = []
    if monospace:
        paths = [
            ("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf",),
            ("/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf",),
            ("/usr/share/fonts/TTF/DejaVuSansMono.ttf",),
        ]
    elif bold:
        paths = [
            ("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",),
            ("/usr/share/fonts/TTF/DejaVuSans-Bold.ttf",),
        ]
    if paths:
        for (path,) in paths:
            if os.path.exists(path):
                try:
                    return ImageFont.truetype(path, size)
                except OSError:
                    pass
    return base_font


def _measure_segments(
    segments: list[tuple[str, dict[str, bool]]],
    draw: ImageDraw.ImageDraw,
    font: ImageFont.FreeTypeFont | ImageFont.ImageFont,
    bold_font: ImageFont.FreeTypeFont | ImageFont.ImageFont,
    italic_font: ImageFont.FreeTypeFont | ImageFont.ImageFont,
    code_font: ImageFont.FreeTypeFont | ImageFont.ImageFont,
) -> float:
    total = 0.0
    for text, flags in segments:
        chosen = font
        if flags.get("code"):
            chosen = code_font
        elif flags.get("bold") and flags.get("italic"):
            chosen = bold_font
        elif flags.get("bold"):
            chosen = bold_font
        elif flags.get("italic"):
            chosen = italic_font
        total += draw.textlength(text, font=chosen)
    return total


def _break_segments_to_lines(
    segments: list[tuple[str, dict[str, bool]]],
    draw: ImageDraw.ImageDraw,
    max_width: int,
    fonts: dict[str, ImageFont.FreeTypeFont | ImageFont.ImageFont],
) -> list[list[tuple[str, dict[str, bool]]]]:
    lines: list[list[tuple[str, dict[str, bool]]]] = [[]]
    current_width = 0.0
    for text, flags in segments:
        chosen = fonts["code"] if flags.get("code") else (
            fonts["bold"] if flags.get("bold") else (
                fonts["italic"] if flags.get("italic") else fonts["regular"]
            )
        )
        words = text.split(" ")
        for index, word in enumerate(words):
            piece = word if index == 0 else f" {word}"
            width = draw.textlength(piece, font=chosen)
            if current_width + width <= max_width or not lines[-1]:
                lines[-1].append((piece, flags))
                current_width += width
            else:
                lines.append([(piece, flags)])
                current_width = width
    return lines


def _draw_segments(
    draw: ImageDraw.ImageDraw,
    x: int,
    y: int,
    segments: list[tuple[str, dict[str, bool]]],
    fonts: dict[str, ImageFont.FreeTypeFont | ImageFont.ImageFont],
) -> int:
    cursor = x
    for piece, flags in segments:
        chosen = fonts["code"] if flags.get("code") else (
            fonts["bold"] if flags.get("bold") else (
                fonts["italic"] if flags.get("italic") else fonts["regular"]
            )
        )
        bbox = draw.textbbox((0, 0), piece, font=chosen)
        draw.text((cursor - bbox[0], y - bbox[1]), piece, fill=0, font=chosen)
        cursor += draw.textlength(piece, font=chosen)
    return cursor


def _parse_markdown_blocks(markdown_text: str) -> list[dict[str, Any]]:
    lines = markdown_text.splitlines()
    blocks: list[dict[str, Any]] = []
    in_code = False
    code_lang = ""
    code_buf: list[str] = []
    list_stack: list[dict[str, Any]] = []

    def close_lists(to_level: int) -> None:
        while len(list_stack) > to_level:
            blocks.append({"type": "list_end"})
            list_stack.pop()

    i = 0
    while i < len(lines):
        line = lines[i]
        if in_code:
            if _MD_FENCE_RE.match(line):
                blocks.append({"type": "code", "lang": code_lang, "lines": code_buf})
                code_buf = []
                in_code = False
            else:
                code_buf.append(line)
            i += 1
            continue
        if _MD_FENCE_RE.match(line):
            close_lists(0)
            in_code = True
            code_lang = line.strip().lstrip("`").strip()
            i += 1
            continue
        stripped = line.strip()
        if not stripped:
            close_lists(0)
            blocks.append({"type": "blank"})
            i += 1
            continue
        if _MD_HR_RE.match(line):
            close_lists(0)
            blocks.append({"type": "hr"})
            i += 1
            continue
        heading = _MD_HEADING_RE.match(line)
        if heading:
            close_lists(0)
            blocks.append({"type": "heading", "level": len(heading.group(1)), "text": heading.group(2).strip()})
            i += 1
            continue
        bq = _MD_BQ_RE.match(line)
        if bq:
            close_lists(0)
            collected = [bq.group(1)]
            j = i + 1
            while j < len(lines):
                next_bq = _MD_BQ_RE.match(lines[j])
                if not next_bq:
                    break
                collected.append(next_bq.group(1))
                j += 1
            blocks.append({"type": "blockquote", "lines": collected})
            i = j
            continue
        uli = _MD_ULI_RE.match(line)
        oli = _MD_OLI_RE.match(line)
        if uli or oli:
            indent = len((uli or oli).group(1))
            level = indent // 2
            while len(list_stack) < level + 1:
                list_stack.append({"type": "ul" if uli else "ol", "counter": 0})
                blocks.append({"type": "list_start", "kind": list_stack[-1]["type"]})
            while len(list_stack) > level + 1:
                blocks.append({"type": "list_end"})
                list_stack.pop()
            current = list_stack[-1]
            if (uli and current["type"] != "ul") or (oli and current["type"] != "ol"):
                blocks.append({"type": "list_end"})
                list_stack.pop()
                list_stack.append({"type": "ul" if uli else "ol", "counter": 0})
                blocks.append({"type": "list_start", "kind": list_stack[-1]["type"]})
                current = list_stack[-1]
            if oli:
                current["counter"] += 1
                marker = f"{current['counter']}."
            else:
                marker = "-"
            text = (uli.group(2) if uli else oli.group(3))
            blocks.append({"type": "list_item", "marker": marker, "text": text, "level": level})
            i += 1
            continue
        close_lists(0)
        blocks.append({"type": "paragraph", "text": line})
        i += 1

    if in_code:
        blocks.append({"type": "code", "lang": code_lang, "lines": code_buf})
    close_lists(0)
    return blocks


def render_markdown(markdown_text: str, options: MarkdownOptions | Settings) -> Image.Image:
    if _markdown is None:
        raise RuntimeError("python-markdown is required for the text tab (pip install markdown)")

    if isinstance(options, Settings):
        opts = MarkdownOptions(font_size=options.font_size, align=options.align)
    else:
        opts = options

    if opts.compact:
        scale = max(0.5, min(1.0, opts.font_size / 32.0))
        opts = MarkdownOptions(
            font_size=opts.font_size,
            align=opts.align,
            margin_x=max(2, int(opts.margin_x * scale * 0.5)),
            margin_y=max(2, int(opts.margin_y * scale * 0.5)),
            line_gap=max(0, opts.line_gap - 1),
            paragraph_gap=max(2, int(opts.paragraph_gap * 0.6)),
            list_indent=max(8, int(opts.list_indent * 0.8)),
            code_padding_x=max(4, int(opts.code_padding_x * 0.7)),
            code_padding_y=max(3, int(opts.code_padding_y * 0.7)),
            heading_h1_delta=max(4, int(opts.heading_h1_delta * 0.7)),
            heading_h2_delta=max(2, int(opts.heading_h2_delta * 0.7)),
            heading_h3_delta=max(2, int(opts.heading_h3_delta * 0.7)),
            heading_h4_delta=max(0, int(opts.heading_h4_delta * 0.6)),
            heading_h5_delta=0,
            heading_h6_delta=0,
            content_width=opts.content_width,
            wrap=opts.wrap,
            hr_padding=max(4, int(opts.hr_padding * 0.6)),
            compact=False,
        )

    body_text = _markdown.markdown(
        markdown_text,
        extensions=["fenced_code", "tables", "sane_lists"],
        output_format="html",
    )
    plain_text = re.sub(r"<[^>]+>", "", body_text).strip()
    if not plain_text:
        plain_text = markdown_text

    base_font = find_font(opts.font_size)
    bold_font = _font_for(base_font, 0, bold=True)
    italic_font = _font_for(base_font, 0, italic=True)
    code_font = _font_for(base_font, 0, monospace=True)
    heading_fonts: dict[int, ImageFont.FreeTypeFont | ImageFont.ImageFont] = {}
    deltas = [
        opts.heading_h1_delta,
        opts.heading_h2_delta,
        opts.heading_h3_delta,
        opts.heading_h4_delta,
        opts.heading_h5_delta,
        opts.heading_h6_delta,
    ]
    for level, delta in enumerate(deltas, start=1):
        heading_fonts[level] = _font_for(base_font, delta, bold=True)

    margin_x = max(0, opts.margin_x)
    margin_y = max(0, opts.margin_y)
    if opts.content_width > 0:
        content_width = min(WIDTH_PX, int(opts.content_width))
        margin_x = max(margin_x, (WIDTH_PX - content_width) // 2)
    else:
        content_width = WIDTH_PX - margin_x * 2
    content_width = max(40, content_width)
    if margin_x * 2 + content_width > WIDTH_PX:
        margin_x = max(0, (WIDTH_PX - content_width) // 2)

    draw = ImageDraw.Draw(Image.new("L", (1, 1), 255))

    blocks = _parse_markdown_blocks(markdown_text)
    layout: list[dict[str, Any]] = []
    list_level = 0

    def get_fonts(flags: dict[str, bool]) -> dict[str, ImageFont.FreeTypeFont | ImageFont.ImageFont]:
        return {
            "regular": base_font,
            "bold": bold_font,
            "italic": italic_font,
            "code": code_font,
        }

    def wrap_lines(text: str, font) -> list[str]:
        if not opts.wrap:
            return [text]
        return _wrap_to_width(text, draw, font, content_width)

    cursor_y = margin_y
    for block in blocks:
        kind = block.get("type")
        if kind == "blank":
            cursor_y += opts.line_gap + 2
            continue
        if kind == "hr":
            cursor_y += max(2, opts.hr_padding // 2)
            layout.append({"type": "hr", "y": cursor_y, "width": content_width})
            cursor_y += max(2, opts.hr_padding - opts.hr_padding // 2)
            continue
        if kind == "heading":
            level = block["level"]
            font = heading_fonts[level]
            wrapped = wrap_lines(block["text"], font)
            for line in wrapped:
                bbox = draw.textbbox((0, 0), line or " ", font=font)
                height = max(1, bbox[3] - bbox[1])
                layout.append({
                    "type": "heading",
                    "y": cursor_y,
                    "height": height,
                    "text": line,
                    "level": level,
                })
                cursor_y += height + max(0, opts.line_gap)
            cursor_y += opts.paragraph_gap
            continue
        if kind == "paragraph":
            segments = _inline_segments(block["text"])
            fonts = get_fonts({})
            if not opts.wrap:
                line_segs = [segments]
            else:
                line_segs = _break_segments_to_lines(segments, draw, content_width, fonts)
            for line_segments in line_segs:
                line_text = "".join(piece for piece, _ in line_segments)
                if not line_text.strip():
                    continue
                bbox = draw.textbbox((0, 0), line_text or " ", font=base_font)
                height = max(1, bbox[3] - bbox[1])
                layout.append({
                    "type": "text",
                    "y": cursor_y,
                    "height": height,
                    "segments": line_segments,
                })
                cursor_y += height + max(0, opts.line_gap)
            cursor_y += opts.paragraph_gap
            continue
        if kind == "blockquote":
            inner_indent = max(8, opts.font_size // 2)
            inner_x = margin_x + inner_indent
            inner_width = max(40, content_width - inner_indent)
            first = True
            for raw_line in block["lines"]:
                if not opts.wrap:
                    wrapped = [raw_line]
                else:
                    wrapped = _wrap_to_width(raw_line, draw, base_font, inner_width)
                for line in wrapped:
                    bbox = draw.textbbox((0, 0), line or " ", font=base_font)
                    height = max(1, bbox[3] - bbox[1])
                    layout.append({
                        "type": "blockquote",
                        "y": cursor_y,
                        "height": height,
                        "text": line,
                        "x": inner_x,
                        "bar_top": cursor_y - 2 if first else None,
                        "bar_bottom": cursor_y + height + 2,
                    })
                    first = False
                    cursor_y += height + max(0, opts.line_gap)
            cursor_y += opts.paragraph_gap
            continue
        if kind == "code":
            code_lines = block.get("lines") or [""]
            inner_width = max(40, content_width - opts.code_padding_x * 2)
            wrapped_lines: list[str] = []
            for raw in code_lines:
                if not raw:
                    wrapped_lines.append("")
                    continue
                if not opts.wrap:
                    wrapped_lines.append(raw)
                    continue
                chunks: list[str] = []
                current = ""
                for token in raw.split(" "):
                    candidate = f"{current} {token}" if current else token
                    if draw.textlength(candidate, font=code_font) <= inner_width:
                        current = candidate
                    else:
                        if current:
                            chunks.append(current)
                        while draw.textlength(token, font=code_font) > inner_width:
                            cut = token[: max(1, len(token) // 2)]
                            chunks.append(cut)
                            token = token[len(cut):]
                        current = token
                if current:
                    chunks.append(current)
                wrapped_lines.extend(chunks)
            line_heights: list[int] = []
            for line in wrapped_lines:
                bbox = draw.textbbox((0, 0), line or " ", font=code_font)
                line_heights.append(max(1, bbox[3] - bbox[1]))
            inner_gap = 2
            block_height = (
                sum(line_heights)
                + (len(wrapped_lines) - 1) * inner_gap
                + opts.code_padding_y * 2
            )
            layout.append({
                "type": "code_block",
                "y": cursor_y,
                "height": block_height,
                "lines": wrapped_lines,
                "line_heights": line_heights,
                "padding_y": opts.code_padding_y,
                "padding_x": opts.code_padding_x,
                "gap": inner_gap,
            })
            cursor_y += block_height + opts.paragraph_gap
            continue
        if kind == "list_start":
            list_level += 1
            continue
        if kind == "list_end":
            list_level = max(0, list_level - 1)
            cursor_y += max(0, opts.line_gap)
            continue
        if kind == "list_item":
            indent = margin_x + list_level * opts.list_indent
            marker = block["marker"]
            segments = _inline_segments(block["text"])
            fonts = get_fonts({})
            marker_width = max(
                draw.textlength(marker + " ", font=base_font),
                opts.list_indent,
            )
            text_x = indent + marker_width
            available = max(40, content_width - (indent - margin_x) - marker_width)
            if not opts.wrap:
                line_segs = [segments]
            else:
                line_segs = _break_segments_to_lines(segments, draw, available, fonts)
            for index, line_segments in enumerate(line_segs):
                line_text = "".join(piece for piece, _ in line_segments)
                bbox = draw.textbbox((0, 0), line_text or " ", font=base_font)
                height = max(1, bbox[3] - bbox[1])
                layout.append({
                    "type": "list_item",
                    "y": cursor_y,
                    "height": height,
                    "segments": line_segments,
                    "marker": marker if index == 0 else "",
                    "marker_x": indent,
                    "text_x": text_x,
                    "level": list_level,
                })
                cursor_y += height + max(0, opts.line_gap)
            continue

    cursor_y += margin_y
    image = Image.new("L", (WIDTH_PX, max(1, cursor_y)), 255)
    draw = ImageDraw.Draw(image)

    align = opts.align
    if align not in {"left", "center", "right"}:
        align = "left"

    for item in layout:
        kind = item["type"]
        if kind == "text":
            x = _align_x(draw, margin_x, content_width, item["segments"], get_fonts({}), align)
            _draw_segments(draw, x, item["y"], item["segments"], get_fonts({}))
        elif kind == "heading":
            font = heading_fonts[item["level"]]
            text = item["text"]
            bbox = draw.textbbox((0, 0), text, font=font)
            text_width = bbox[2] - bbox[0]
            if align == "center":
                x = max(margin_x, margin_x + (content_width - text_width) // 2)
            elif align == "right":
                x = max(margin_x, margin_x + content_width - text_width)
            else:
                x = margin_x
            draw.text((x - bbox[0], item["y"] - bbox[1]), text, fill=0, font=font)
            if item["level"] <= 2:
                underline_y = item["y"] + item["height"] + 2
                draw.line((x, underline_y, x + text_width, underline_y), fill=0, width=1)
        elif kind == "hr":
            y = item["y"]
            dash_width = 6
            gap = 4
            x = margin_x
            while x < margin_x + content_width:
                draw.line((x, y, min(x + dash_width, margin_x + content_width), y), fill=0, width=1)
                x += dash_width + gap
        elif kind == "blockquote":
            text = item["text"]
            bbox = draw.textbbox((0, 0), text, font=base_font)
            draw.text((item["x"] - bbox[0], item["y"] - bbox[1]), text, fill=0, font=base_font)
            if item.get("bar_top") is not None:
                draw.rectangle((margin_x + 4, item["bar_top"], margin_x + 7, item["bar_bottom"]), fill=180)
        elif kind == "code_block":
            draw.rectangle(
                (margin_x, item["y"], margin_x + content_width, item["y"] + item["height"]),
                outline=0,
                width=1,
            )
            y = item["y"] + item["padding_y"]
            for line, line_height in zip(item["lines"], item["line_heights"]):
                bbox = draw.textbbox((0, 0), line or " ", font=code_font)
                draw.text(
                    (margin_x + item["padding_x"] - bbox[0], y - bbox[1]),
                    line,
                    fill=0,
                    font=code_font,
                )
                y += line_height + item["gap"]
        elif kind == "list_item":
            if item["marker"]:
                marker_bbox = draw.textbbox((0, 0), item["marker"], font=base_font)
                if align == "right":
                    marker_x = margin_x + content_width - _segments_width(draw, item["segments"], get_fonts({})) - marker_bbox[2] + marker_bbox[0]
                    text_x = margin_x + content_width - _segments_width(draw, item["segments"], get_fonts({}))
                else:
                    marker_x = item["marker_x"]
                    text_x = item["text_x"]
                draw.text(
                    (marker_x - marker_bbox[0], item["y"] - marker_bbox[1]),
                    item["marker"],
                    fill=0,
                    font=base_font,
                )
                if align == "right":
                    _draw_segments_right(
                        draw, text_x, item["y"], item["segments"],
                        margin_x + content_width, get_fonts({}),
                    )
                else:
                    _draw_segments(draw, text_x, item["y"], item["segments"], get_fonts({}))
            else:
                if align == "right":
                    text_x = margin_x + content_width - _segments_width(draw, item["segments"], get_fonts({}))
                    _draw_segments_right(
                        draw, text_x, item["y"], item["segments"],
                        margin_x + content_width, get_fonts({}),
                    )
                else:
                    _draw_segments(draw, item["text_x"], item["y"], item["segments"], get_fonts({}))

    return image


def _segments_width(draw, segments, fonts) -> float:
    total = 0.0
    for text, flags in segments:
        chosen = fonts["code"] if flags.get("code") else (
            fonts["bold"] if flags.get("bold") else (
                fonts["italic"] if flags.get("italic") else fonts["regular"]
            )
        )
        total += draw.textlength(text, font=chosen)
    return total


def _align_x(draw, margin_x: int, content_width: int, segments, fonts, align: str) -> int:
    if align == "center":
        text_width = _segments_width(draw, segments, fonts)
        return max(margin_x, margin_x + (content_width - text_width) // 2)
    if align == "right":
        text_width = _segments_width(draw, segments, fonts)
        return max(margin_x, margin_x + content_width - text_width)
    return margin_x


def _draw_segments_right(draw, x_right: int, y: int, segments, right_edge: int, fonts) -> None:
    cursor = x_right
    for text, flags in segments:
        chosen = fonts["code"] if flags.get("code") else (
            fonts["bold"] if flags.get("bold") else (
                fonts["italic"] if flags.get("italic") else fonts["regular"]
            )
        )
        bbox = draw.textbbox((0, 0), text, font=chosen)
        draw.text((cursor - bbox[0], y - bbox[1]), text, fill=0, font=chosen)
        cursor += draw.textlength(text, font=chosen)


def trim_whitespace(image: Image.Image, padding: int = 6) -> Image.Image:
    inverted = ImageOps.invert(image.convert("L"))
    bbox = inverted.point(lambda pixel: 255 if pixel > 12 else 0).getbbox()
    if not bbox:
        return image

    left, top, right, bottom = bbox
    left = max(0, left - padding)
    top = max(0, top - padding)
    right = min(image.width, right + padding)
    bottom = min(image.height, bottom + padding)
    return image.crop((left, top, right, bottom))


def orient_image(image: Image.Image, settings: Settings) -> Image.Image:
    if settings.orientation == "rotate-cw":
        return image.transpose(Image.Transpose.ROTATE_270)
    if settings.orientation == "rotate-ccw":
        return image.transpose(Image.Transpose.ROTATE_90)
    if settings.orientation != "auto":
        return image

    # Desktop print dialogs frequently rotate images onto short receipt pages.
    # If the useful content is clearly landscape, turn it back so the narrow
    # printer head is the image width and the paper feed direction is height.
    if image.width > image.height * 1.2:
        return image.transpose(Image.Transpose.ROTATE_90)
    return image


def apply_tone(image: Image.Image, settings: Settings) -> Image.Image:
    image = image.convert("L")
    if settings.brightness != 1.0:
        image = ImageEnhance.Brightness(image).enhance(settings.brightness)
    if settings.contrast != 1.0:
        image = ImageEnhance.Contrast(image).enhance(settings.contrast)
    if settings.gamma != 1.0:
        inv_gamma = 1.0 / settings.gamma
        table = [min(255, max(0, round(((i / 255) ** inv_gamma) * 255))) for i in range(256)]
        image = image.point(table)
    if settings.invert:
        image = ImageOps.invert(image)
    return image


def normalize_image(image: Image.Image, settings: Settings) -> Image.Image:
    image = ImageOps.exif_transpose(image)
    image = image.convert("L")
    if settings.trim:
        image = trim_whitespace(image)
    image = orient_image(image, settings)

    if settings.scale == "fit-width" and image.width != WIDTH_PX:
        ratio = WIDTH_PX / image.width
        height = max(1, int(image.height * ratio))
        image = image.resize((WIDTH_PX, height), Image.Resampling.LANCZOS)
    elif image.width > WIDTH_PX:
        image = image.crop((0, 0, WIDTH_PX, image.height))
    elif image.width < WIDTH_PX:
        canvas = Image.new("L", (WIDTH_PX, image.height), 255)
        canvas.paste(image, (0, 0))
        image = canvas

    return apply_tone(image, settings)


def ordered_dither(image: Image.Image, settings: Settings) -> Image.Image:
    matrix4 = (
        (0, 8, 2, 10),
        (12, 4, 14, 6),
        (3, 11, 1, 9),
        (15, 7, 13, 5),
    )
    matrix8 = (
        (0, 48, 12, 60, 3, 51, 15, 63),
        (32, 16, 44, 28, 35, 19, 47, 31),
        (8, 56, 4, 52, 11, 59, 7, 55),
        (40, 24, 36, 20, 43, 27, 39, 23),
        (2, 50, 14, 62, 1, 49, 13, 61),
        (34, 18, 46, 30, 33, 17, 45, 29),
        (10, 58, 6, 54, 9, 57, 5, 53),
        (42, 26, 38, 22, 41, 25, 37, 21),
    )
    matrix = matrix4 if settings.ordered_size == 4 else matrix8
    size = len(matrix)
    spread = 16 if size == 4 else 4
    threshold_offset = settings.threshold - 128
    src = image.convert("L")
    out = Image.new("1", src.size, 1)
    in_pixels = src.load()
    out_pixels = out.load()
    for y in range(src.height):
        row = matrix[y % size]
        for x in range(src.width):
            cutoff = row[x % size] * spread + threshold_offset
            out_pixels[x, y] = 0 if in_pixels[x, y] < cutoff else 1
    return out


def error_diffusion_dither(image: Image.Image, settings: Settings, algorithm: str) -> Image.Image:
    src = image.convert("L")
    width, height = src.size
    values = [[float(src.getpixel((x, y))) for x in range(width)] for y in range(height)]
    out = Image.new("1", src.size, 1)
    out_pixels = out.load()

    if algorithm == "atkinson":
        kernel = ((1, 0, 1 / 8), (2, 0, 1 / 8), (-1, 1, 1 / 8), (0, 1, 1 / 8), (1, 1, 1 / 8), (0, 2, 1 / 8))
    else:
        kernel = ((1, 0, 7 / 16), (-1, 1, 3 / 16), (0, 1, 5 / 16), (1, 1, 1 / 16))

    for y in range(height):
        reverse = settings.serpentine and y % 2 == 1
        xs = range(width - 1, -1, -1) if reverse else range(width)
        for x in xs:
            old = values[y][x]
            new = 0.0 if old < settings.threshold else 255.0
            out_pixels[x, y] = 0 if new == 0.0 else 1
            error = (old - new) * settings.dither_strength
            for dx, dy, factor in kernel:
                tx = x - dx if reverse else x + dx
                ty = y + dy
                if 0 <= tx < width and 0 <= ty < height:
                    values[ty][tx] = min(255.0, max(0.0, values[ty][tx] + error * factor))
    return out


def binarize_image(image: Image.Image, settings: Settings) -> Image.Image:
    image = image.convert("L")
    if settings.dither == "grayscale":
        return image
    if settings.dither == "floyd-steinberg":
        return error_diffusion_dither(image, settings, "floyd-steinberg")
    if settings.dither == "atkinson":
        return error_diffusion_dither(image, settings, "atkinson")
    if settings.dither == "ordered":
        return ordered_dither(image, settings)
    return image.point(lambda pixel: 0 if pixel < settings.threshold else 255, mode="1")


def prepare_image(image: Image.Image, settings: Settings) -> Image.Image:
    return binarize_image(normalize_image(image, settings), settings)


def image_to_lines(image: Image.Image) -> list[bytes]:
    bw = image.convert("1")
    lines = []
    for y in range(bw.height):
        row = bytearray(WIDTH_BYTES)
        for x in range(WIDTH_PX):
            if bw.getpixel((x, y)) == 0:
                row[x // 8] |= 1 << (x % 8)
        lines.append(bytes(row))
    return lines


def send(sock: socket.socket, command: int, payload: bytes = b"") -> None:
    sock.sendall(frame(command, payload))


def grayscale_print_commands(image: Image.Image, block_lines: int = 20) -> list[bytes]:
    if lzo is None:
        raise RuntimeError("python-lzo is required for grayscale printing")

    image = image.convert("L")
    if image.width != WIDTH_PX:
        raise ValueError(f"grayscale image width must be {WIDTH_PX}px")

    line_len = WIDTH_PX
    block_len = line_len * block_lines
    intensities = bytearray()
    for pixel in image.getdata():
        intensities.append(255 - pixel)

    while len(intensities) % block_len != 0:
        intensities.extend(bytes(line_len))

    commands = []
    for block_start in range(0, len(intensities), block_len):
        block = bytes(intensities[block_start:block_start + block_len])
        packed = bytearray()
        for i in range(0, len(block), 2):
            p0 = block[i] >> 4
            p1 = block[i + 1] >> 4 if i + 1 < len(block) else 0
            packed.append((p0 << 4) | p1)
        compressed = lzo.compress(bytes(packed), 1, False)
        payload = len(packed).to_bytes(2, "little") + len(compressed).to_bytes(2, "little") + compressed
        commands.append(frame(0xCF, payload))
    return commands


def send_grayscale_image(sock: socket.socket, image: Image.Image, settings: Settings) -> None:
    for command in grayscale_print_commands(image):
        sock.sendall(command)
        time.sleep(settings.line_delay)


def print_prepared_images(images: list[Image.Image], settings: Settings, copies: int = 1) -> None:
    if not settings.addr:
        raise RuntimeError("printer address is required")

    cups_log("INFO", f"Connecting to {settings.addr} channel {settings.channel}")
    sock = socket.socket(socket.AF_BLUETOOTH, socket.SOCK_STREAM, socket.BTPROTO_RFCOMM)
    sock.settimeout(30)
    sock.connect((settings.addr, settings.channel))
    try:
        send(sock, 0xA4, bytes([settings.quality]))
        send(sock, 0xAF, settings.darkness.to_bytes(2, "little"))
        send(sock, 0xBD, bytes([settings.speed]))
        send(sock, 0xBE, bytes([0]))
        time.sleep(0.05)

        blank = bytes(WIDTH_BYTES)
        for _copy in range(copies):
            for image in images:
                if settings.dither == "grayscale":
                    send_grayscale_image(sock, image, settings)
                    send(sock, 0xA1, settings.feed_lines.to_bytes(2, "little"))
                else:
                    for line in image_to_lines(image):
                        send(sock, 0xA2, line)
                        time.sleep(settings.line_delay)
                    for _ in range(settings.feed_lines):
                        send(sock, 0xA2, blank)
                        time.sleep(0.005)
    finally:
        sock.close()


def print_images(images: list[Image.Image], settings: Settings, copies: int = 1) -> None:
    print_prepared_images([prepare_image(image, settings) for image in images], settings, copies)


def discovery() -> int:
    print('direct x6h-rfcomm "Unknown" "X6H RFCOMM thermal printer"')
    return 0


def run_cups_backend() -> int:
    if len(sys.argv) == 1:
        return discovery()
    if len(sys.argv) not in {6, 7}:
        cups_log("ERROR", "Usage: x6h-rfcomm job-id user title copies options [file]")
        return 1

    copies = int(sys.argv[4])
    settings = Settings()
    settings = parse_device_uri(os.environ.get("DEVICE_URI", ""), settings)
    settings = parse_cups_options(sys.argv[5], settings)
    if os.environ.get("X6H_ADDR"):
        settings = replace(settings, addr=os.environ["X6H_ADDR"].replace("-", ":").upper())

    data = Path(sys.argv[6]).read_bytes() if len(sys.argv) == 7 else sys.stdin.buffer.read()
    images = image_from_bytes(data, settings)
    print_images(images, settings, copies=max(1, copies))
    return 0


def run_cli() -> int:
    parser = argparse.ArgumentParser(description="Print to an X6H RFCOMM thermal printer.")
    parser.add_argument("text", nargs="*", help="Text to print when --file is not provided")
    parser.add_argument("--file", "-f", type=Path, help="File to print: text, image, PDF, or PostScript")
    parser.add_argument("--addr", default=os.environ.get("X6H_ADDR"), help="Bluetooth MAC address")
    parser.add_argument("--channel", type=int, default=1)
    parser.add_argument("--darkness", "--energy", type=int, default=9500)
    parser.add_argument("--speed", type=int, default=10)
    parser.add_argument("--quality", type=int, default=3)
    parser.add_argument("--threshold", type=int, default=180)
    parser.add_argument("--font-size", type=int, default=32)
    parser.add_argument("--feed-lines", type=int, default=80)
    parser.add_argument("--align", choices=["left", "center", "right"], default="left")
    parser.add_argument("--scale", choices=["fit-width", "native"], default="fit-width")
    parser.add_argument("--dither", choices=["grayscale", "none", "threshold", "floyd-steinberg", "ordered", "atkinson"], default="none")
    parser.add_argument("--dither-strength", type=float, default=1.0)
    parser.add_argument("--ordered-size", type=int, choices=[4, 8], default=8)
    parser.add_argument("--no-serpentine", action="store_true")
    parser.add_argument("--brightness", type=float, default=1.0)
    parser.add_argument("--contrast", type=float, default=1.0)
    parser.add_argument("--gamma", type=float, default=1.0)
    parser.add_argument("--invert", action="store_true")
    parser.add_argument("--orientation", choices=["auto", "as-is", "rotate-cw", "rotate-ccw"], default="auto")
    parser.add_argument("--no-trim", action="store_true", help="Do not remove white margins before printing")
    args = parser.parse_args()

    settings = Settings(
        addr=args.addr.replace("-", ":").upper() if args.addr else None,
        channel=args.channel,
        darkness=args.darkness,
        speed=args.speed,
        quality=args.quality,
        threshold=args.threshold,
        font_size=args.font_size,
        feed_lines=args.feed_lines,
        align=args.align,
        scale=args.scale,
        dither=args.dither,
        dither_strength=args.dither_strength,
        ordered_size=args.ordered_size,
        serpentine=not args.no_serpentine,
        brightness=args.brightness,
        contrast=args.contrast,
        gamma=args.gamma,
        invert=args.invert,
        orientation=args.orientation,
        trim=not args.no_trim,
    )

    if args.file:
        data = args.file.read_bytes()
    else:
        data = (" ".join(args.text) or sys.stdin.read()).encode()
    print_images(image_from_bytes(data, settings), settings)
    return 0


def main() -> int:
    backend_name = Path(sys.argv[0]).name
    try:
        if backend_name == "x6h-rfcomm" or os.environ.get("X6H_CUPS_BACKEND") == "1":
            return run_cups_backend()
        return run_cli()
    except Exception as exc:
        cups_log("ERROR", str(exc))
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
